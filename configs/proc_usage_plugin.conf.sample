# Путь, куда сборщик пишет компактные `JSONL`-snapshot-файлы.
spool_dir = /tmp/firebird_proc_usage_spool

# Необязательный debug-log, который пишет сам процесс плагина Firebird.
debug_log_path = /tmp/proc_usage_trace_debug.log

# Как часто счетчики из памяти сбрасываются в spool-файлы.
flush_interval_sec = 30

# По умолчанию собираем timing и обычных SQL statement'ов, и процедур.
enable_sql_stats = true

# Полные тексты SQL храним отдельно и выключаем по умолчанию, чтобы не
# раздувать spool и SQLite без явного решения.
enable_sql_text_stats = false

# Необязательный allow-list фрагментов пути к БД, разделенных `;`.
# Оставьте пустым, чтобы учитывать все базы.
include_databases =

# Необязательный deny-list фрагментов пути к БД, разделенных `;`.
exclude_databases =
